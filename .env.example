DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Cloudflare Turnstile — test keys (always pass, safe for local dev)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Email (SMTP via nodemailer). When SMTP_HOST is unset, emails are logged to the
# console and submissions still save. Set these to actually deliver mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@kagency.dev
EMAIL_FROM_NAME=Kagency
# Where contact-form submissions are emailed
CONTACT_TO=submissions@kagency.dev

# Programmatic publishing (scripts/publish/*) — see scripts/publish/README.md
PAYLOAD_URL=http://localhost:3000
PAYLOAD_API_KEY=
